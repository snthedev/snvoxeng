#version 460

layout (local_size_x = 16, local_size_y = 16, local_size_z = 1) in;
layout(set = 0, binding = 0, rgba8) uniform writeonly image2D u_Canvas;

vec4 sky_color = vec4(0.15, 0.05, 0.45, 1.0);

vec4 light_color = vec4(40.0, 40.0, 40.0, 1.0);
vec3 light_direction = normalize(vec3(-0.7, -1.0, 0.2));

vec4 sphere_color = vec4(0.95, 0.7, 0.7, 1.0);
vec3 sphere_origin = vec3(0.0, 0.0, 60.0);
float sphere_radius = 20.0;

vec3 getNormal_sphere(in vec3 point, in vec3 sphere_origin)
{
    return normalize(point - sphere_origin);
}

bool getIntersect_sphere(in vec3 ro, in vec3 rd, in vec3 sphere_origin, in float sphere_radius, out vec3 p0, out vec3 p1)
{
    vec3 target = sphere_origin - ro;

    // closest point to sphere is ro + t * rd
    float t = (rd.x * target.x + rd.y * target.y + rd.z * target.z) / (rd.x * rd.x + rd.y * rd.y + rd.z * rd.z);
    vec3 p_closest = ro + t * rd;

    float r_sq = sphere_radius * sphere_radius;

    vec3 p_closest_dir = p_closest - sphere_origin;
    float dst_sq = p_closest_dir.x * p_closest_dir.x + p_closest_dir.y * p_closest_dir.y + p_closest_dir.z * p_closest_dir.z;
    if (dst_sq > r_sq * 0.9995) return false;

    float hit_radius = sqrt(r_sq - dst_sq);
    p0 = p_closest - hit_radius * rd;
    p1 = p_closest + hit_radius * rd;

    return true;
}

void main()
{
    ivec2 texelCoords = ivec2(gl_GlobalInvocationID.xy);
    ivec2 size = imageSize(u_Canvas);
    vec2 aspect = vec2(
        min(1.0, float(size.x) / float(size.y)),
        min(1.0, float(size.y) / float(size.x))
    );

    if (texelCoords.x < size.x && texelCoords.y < size.y)
    {
        vec2 uv = vec2(float(texelCoords.x) / float(size.x) - 0.5, float(texelCoords.y) / float(size.y) - 0.5) * aspect * 2.0;

        vec3 ro = vec3(
            0.0,
            0.0,
            0.0
        );
        vec3 rd = normalize(vec3(
            uv.x,
            uv.y,
            1.0
        ));

        vec4 color = vec4(1.0, 1.0, 1.0, 1.0);

        vec3 p0 = vec3(0.0, 0.0, 0.0);
        vec3 p1 = vec3(0.0, 0.0, 0.0);
        if (getIntersect_sphere(ro, rd, sphere_origin, sphere_radius, p0, p1))
        {
            vec3 p0_n = getNormal_sphere(p0, sphere_origin);
            rd = reflect(rd, p0_n);
            color = color * sphere_color;
        }

        float light_dot = dot(rd, -light_direction);
        float light_dot_p = max(0.0, light_dot);
        float light_dot_n = max(0.0, -light_dot);

        float light_scalar = (
            1.0 * pow(light_dot_p, 256.0)
            + 0.10 * pow(light_dot_p, 1.2)
            + 0.005
            ) / (1.0 + 0.1 + 0.005);
        float light_scalar_n = 1.0 - light_scalar;
        color = color * (light_color * light_scalar + sky_color * light_scalar_n);

        color = vec4(
            pow(0.509295817894 * atan(color.b) + 0.2, 2.2),
            pow(0.509295817894 * atan(color.g) + 0.2, 2.2),
            pow(0.509295817894 * atan(color.r) + 0.2, 2.2),
            color.a
        );
        imageStore(u_Canvas, texelCoords, color);
    }
}